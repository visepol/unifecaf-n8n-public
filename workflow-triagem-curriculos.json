        {
            "parameters": {
                "sendTo": "={{ $json.Email }}",
                "subject": "Resposta do Processo Seletivo - Pr\u00f3ximas Etapas",
                "message": "Prezado(a) Candidato(a),\n\nAgradecemos seu interesse em fazer parte da nossa equipe.\n\nAp\u00f3s an\u00e1lise do seu curr\u00edculo, temos o prazer de informar que seu perfil foi selecionado para a pr\u00f3xima etapa do processo seletivo.\n\nNossa equipe de RH entrar\u00e1 em contato em breve para agendar uma entrevista.\n\nAtenciosamente,\nEquipe de Recrutamento",
                "options": {}
            },
